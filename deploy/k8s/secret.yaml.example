# Secret manifest example for the Hyperping exporter.
#
# Usage (preferred — avoids storing the key in the object's last-applied-configuration annotation):
#   kubectl create secret generic hyperping-credentials \
#     --from-literal=api-key=YOUR_KEY \
#     -n monitoring
#
# Alternative (kubectl apply leaks the key in plaintext inside the
# last-applied-configuration annotation — use only if you understand the risk):
#   1. Copy this file: cp secret.yaml.example secret.yaml
#   2. Replace REPLACE_WITH_ACTUAL_KEY with your Hyperping API key.
#   3. kubectl apply -f deploy/k8s/secret.yaml -n monitoring
#
# Note: secret.yaml is listed in .gitignore and must never be committed.
apiVersion: v1
kind: Secret
metadata:
  name: hyperping-credentials
  namespace: monitoring
type: Opaque
stringData:
  api-key: "REPLACE_WITH_ACTUAL_KEY"
