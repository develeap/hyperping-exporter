# Secret manifest example for the Hyperping exporter.
#
# Usage:
#   1. Copy this file to secret.yaml in this directory:
#        cp secret.yaml.example secret.yaml
#   2. Replace REPLACE_WITH_ACTUAL_KEY with your Hyperping API key.
#   3. Apply the Secret before the Deployment:
#        kubectl apply -f deploy/k8s/secret.yaml
#        kubectl apply -f deploy/k8s/deployment.yaml
#
# Note: secret.yaml is listed in .gitignore and must never be committed.
apiVersion: v1
kind: Secret
metadata:
  name: hyperping-credentials
  namespace: monitoring
type: Opaque
stringData:
  api-key: "REPLACE_WITH_ACTUAL_KEY"
