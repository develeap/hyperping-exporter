# Copy this file to deploy/.env and fill in your values.
# deploy/.env is gitignored — never commit it with real credentials.

# Required: your Hyperping API key
# Get it at: Hyperping → Account Settings → API → Create API Key
HYPERPING_API_KEY=your_hyperping_api_key_here

# Required: Grafana admin password (used only in the full compose stack)
GRAFANA_ADMIN_PASSWORD=change_me
